#!/bin/sh
# dirlens - wrapper for dirlens.py
#
# Follows symlinks to locate dirlens.py correctly when installed via npm globally.
# npm installs bin entries as symlinks, so plain dirname "$0" would point to the
# wrong directory. The while loop resolves the full symlink chain portably on
# both macOS (BSD readlink) and Linux (GNU readlink).
#
# To override the Python interpreter (e.g. in sandboxed environments):
#   export DIRLENS_PYTHON=/usr/bin/python3
# Interpreter resolution order: $DIRLENS_PYTHON -> python3 -> python -> py.
# Windows' official Python often exposes only `python` / `py` (no `python3`),
# so the wrapper falls back through these instead of hardcoding python3.

self="$0"
while [ -L "$self" ]; do
  link="$(readlink "$self")"
  case "$link" in
    /*) self="$link" ;;
    *)  self="$(dirname "$self")/$link" ;;
  esac
done
dir="$(cd "$(dirname "$self")/.." && pwd)"

if [ -n "$DIRLENS_PYTHON" ]; then
  python="$DIRLENS_PYTHON"
elif command -v python3 >/dev/null 2>&1; then
  python=python3
elif command -v python >/dev/null 2>&1; then
  python=python
elif command -v py >/dev/null 2>&1; then
  python=py
else
  echo "dirlens: Python が見つかりません (python3 / python / py)。Python 3.8+ をインストールしてください。" >&2
  exit 1
fi
exec "$python" "$dir/dirlens.py" "$@"
