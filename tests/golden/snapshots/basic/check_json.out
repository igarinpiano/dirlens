{
  "schema_version": 1,
  "capabilities": {
    "gitignore_tier": "builtin",
    "outline": {
      "python": "ast",
      "js_ts": "ast",
      "rust": "ast",
      "go": "ast",
      "c": "ast",
      "java": "ast",
      "ruby": "ast",
      "php": "ast",
      "csharp": "ast",
      "kotlin": "ast",
      "swift": "ast",
      "html": "ast (embedded js)",
      "fallback": "regex"
    },
    "imports_resolution": [
      "relative",
      "tsconfig-paths",
      "package-imports",
      "go-module",
      "rust-module-tree"
    ],
    "git_log": true,
    "clipboard": false,
    "tokens": "bpe-o200k_base"
  },
  "degraded": [
    "target is not a git work tree (gitignore uses builtin matcher)",
    "no clipboard tool found (-C unavailable)"
  ],
  "best": false
}
